# Optional: API key for live GNews refresh scripts.
GNEWS_API_KEY=

# Database connection string (default uses local SQLite file).
DATABASE_URL=sqlite:///one-i.db

# Application metadata.
APP_NAME=ONE-I

# Scheduler controls.
ENABLE_SCHEDULER=false
INGEST_INTERVAL_HOURS=6

# Required by Reddit API for reaction refresh script.
REDDIT_USER_AGENT=ONE-I/0.1
